{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/steering-index.sh\" 2>/dev/null || true",
            "statusMessage": "steering 인덱스 회상 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/steering-stop.sh\""
          }
        ]
      }
    ]
  }
}
