{
  "name": "votatis-intake-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --var LOCAL_UPLOAD:true",
    "dev:local": "wrangler dev --var LOCAL_UPLOAD:true",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply votatis-reports --local",
    "db:migrate:remote": "wrangler d1 migrations apply votatis-reports --remote",
    "openapi:emit": "tsx scripts/emit-openapi.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.3",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.2",
    "@cloudflare/workers-types": "^4.20240925.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vitest": "2.0.5",
    "wrangler": "^3.78.0"
  }
}
