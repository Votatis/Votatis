{
  "openapi": "3.1.0",
  "info": {
    "title": "Votatis Intake API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "SubmissionCreated": {
        "type": "object",
        "properties": {
          "submission_id": {
            "type": "string"
          },
          "finalize_token": {
            "type": "string"
          },
          "uploads": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "staging_key": {
                  "type": "string"
                },
                "put_url": {
                  "type": "string"
                }
              },
              "required": [
                "staging_key",
                "put_url"
              ]
            }
          }
        },
        "required": [
          "submission_id",
          "finalize_token",
          "uploads"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "Region": {
        "type": "object",
        "properties": {
          "sido": {
            "type": "string"
          },
          "sigungu": {
            "type": "string"
          },
          "eup_myeon_dong": {
            "type": "string"
          }
        }
      },
      "Source": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "captured_at": {
            "type": "string"
          },
          "archive_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "AttachmentInput": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "minLength": 1
          },
          "mime": {
            "type": "string",
            "enum": [
              "image/jpeg",
              "image/png",
              "image/gif",
              "image/webp"
            ]
          },
          "size": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 15728640
          },
          "sha256": {
            "type": "string"
          }
        },
        "required": [
          "filename",
          "mime",
          "size"
        ]
      },
      "SubmissionInput": {
        "type": "object",
        "properties": {
          "election": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "region": {
            "$ref": "#/components/schemas/Region"
          },
          "occurred_at": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 50
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Source"
            }
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AttachmentInput"
            },
            "maxItems": 10
          },
          "exif": {
            "type": "array",
            "items": {}
          },
          "consent": {
            "type": "boolean"
          },
          "turnstile_token": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "election",
          "title",
          "turnstile_token"
        ]
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string"
          },
          "r2_key": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "mime": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          }
        },
        "required": [
          "filename",
          "r2_key",
          "sha256",
          "mime",
          "size"
        ]
      },
      "FinalizeResult": {
        "type": "object",
        "properties": {
          "report_id": {
            "type": "string"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          }
        },
        "required": [
          "report_id",
          "attachments"
        ]
      },
      "FinalizeInput": {
        "type": "object",
        "properties": {
          "finalize_token": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "finalize_token"
        ]
      },
      "ReportSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "election": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "region": {
            "$ref": "#/components/schemas/Region"
          },
          "occurred_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "collected_at": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "attachment_count": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "status",
          "election",
          "title",
          "summary",
          "region",
          "occurred_at",
          "collected_at",
          "tags",
          "attachment_count"
        ]
      },
      "ReportList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReportSummary"
            }
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        },
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ]
      },
      "Verification": {
        "type": "object",
        "properties": {
          "reviewer": {
            "type": [
              "string",
              "null"
            ]
          },
          "method": {
            "type": [
              "string",
              "null"
            ]
          },
          "reviewed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_links": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "reviewer",
          "method",
          "reviewed_at",
          "notes",
          "evidence_links"
        ]
      },
      "Report": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "election": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "body": {
            "type": [
              "string",
              "null"
            ]
          },
          "region": {
            "$ref": "#/components/schemas/Region"
          },
          "occurred_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "collected_at": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Source"
            }
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          },
          "rebuttals": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "source_url": {
                  "type": "string"
                }
              },
              "required": [
                "text"
              ]
            }
          },
          "related": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "consent": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "license": {
            "type": "string"
          },
          "verification": {
            "$ref": "#/components/schemas/Verification"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "status",
          "election",
          "title",
          "summary",
          "body",
          "region",
          "occurred_at",
          "collected_at",
          "tags",
          "sources",
          "attachments",
          "rebuttals",
          "related",
          "consent",
          "license",
          "verification",
          "created_at",
          "updated_at"
        ]
      },
      "AdminSessionResult": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "ok"
        ]
      },
      "AdminSessionInput": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "token"
        ]
      },
      "AdminReportSummary": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ReportSummary"
          },
          {
            "type": "object",
            "properties": {
              "submitter": {
                "type": "string"
              },
              "updated_at": {
                "type": "string"
              }
            },
            "required": [
              "submitter",
              "updated_at"
            ]
          }
        ]
      },
      "AdminReportList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminReportSummary"
            }
          },
          "total": {
            "type": "integer"
          },
          "counts": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        },
        "required": [
          "items",
          "total",
          "counts",
          "limit",
          "offset"
        ]
      },
      "AdminReportDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Report"
          },
          {
            "type": "object",
            "properties": {
              "submitter": {
                "type": "string"
              },
              "exif": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {}
              }
            },
            "required": [
              "submitter",
              "exif"
            ]
          }
        ]
      },
      "AdminPatch": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "unverified",
              "reviewing",
              "confirmed",
              "disputed",
              "debunked",
              "corrected"
            ]
          },
          "reviewer": {
            "type": "string"
          },
          "verification": {
            "type": "object",
            "properties": {
              "reviewer": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "method": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "notes": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "evidence_links": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 50
          },
          "rebuttals": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string",
                  "minLength": 1
                },
                "source_url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "text"
              ]
            }
          },
          "related": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        }
      },
      "Analysis": {
        "type": "object",
        "properties": {
          "suggested_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "credibility": {
            "type": "object",
            "properties": {
              "score": {
                "type": "number"
              },
              "signals": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "score",
              "signals"
            ]
          },
          "synthetic_risk": {
            "type": "object",
            "properties": {
              "level": {
                "type": "string",
                "enum": [
                  "low",
                  "review",
                  "unknown"
                ]
              },
              "signals": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "level",
              "signals"
            ]
          },
          "summary_hint": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "heuristic",
              "heuristic+ai"
            ]
          }
        },
        "required": [
          "suggested_tags",
          "credibility",
          "synthetic_risk",
          "summary_hint",
          "source"
        ]
      },
      "AdminExport": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Report"
            }
          }
        },
        "required": [
          "records"
        ]
      },
      "Stats": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "by_status": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          },
          "by_election": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "election": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                }
              },
              "required": [
                "election",
                "count"
              ]
            }
          },
          "daily": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                }
              },
              "required": [
                "date",
                "count"
              ]
            }
          }
        },
        "required": [
          "total",
          "by_status",
          "by_election",
          "daily"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/submissions": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmissionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "제출 개시 — presigned 업로드 URL 발급",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionCreated"
                }
              }
            }
          },
          "400": {
            "description": "유효하지 않은 요청",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Turnstile/오리진 거부",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "rate limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/submissions/{id}/finalize": {
      "post": {
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FinalizeInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "확정 — D1 레코드 적재",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FinalizeResult"
                }
              }
            }
          },
          "400": {
            "description": "검증 실패(업로드 누락/타입/크기)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "토큰 불일치",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "제출 없음/만료",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/reports": {
      "get": {
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "election",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "unverified",
                "reviewing",
                "confirmed",
                "disputed",
                "debunked",
                "corrected"
              ]
            },
            "required": false,
            "name": "status",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "sido",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "sigungu",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "tag",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "from",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "to",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100,
              "default": 20
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0,
              "default": 0
            },
            "required": false,
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "제보 목록(pending 제외)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportList"
                }
              }
            }
          },
          "400": {
            "description": "유효하지 않은 쿼리",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/reports/{id}": {
      "get": {
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "제보 상세",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Report"
                }
              }
            }
          },
          "404": {
            "description": "없음(또는 pending)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/admin/session": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminSessionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "토큰 유효",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminSessionResult"
                }
              }
            }
          },
          "401": {
            "description": "토큰 불일치",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/admin/reports": {
      "get": {
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "unverified",
                "reviewing",
                "confirmed",
                "disputed",
                "debunked",
                "corrected"
              ]
            },
            "required": false,
            "name": "status",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "election",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "sido",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
